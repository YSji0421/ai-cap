# 클라이언트 빌드 시점에 사용 (REACT_APP_ 접두사 필요)
REACT_APP_GEMINI_API_KEY=

# 백엔드 베이스 URL (없으면 /api 프록시로 fallback — local dev 전용)
# 예) https://adjuster-system-production.up.railway.app
REACT_APP_API_BASE_URL=

# 서버리스 함수 (api/emergency-notify.js) 전용 — 클라이언트 번들에 노출되지 않음
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=
COUNSELOR_EMAIL=
